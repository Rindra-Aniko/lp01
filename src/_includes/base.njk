<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default('Perysmith M2 Pro Max') }}</title>
    <meta name="description" content="Perysmith M2 Pro Max - Spot Cleaner terbaik dengan teknologi uap panas 100°C, AI Voice, dan daya hisap 20.000 Pa">
    
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.domain }}">
    <meta property="og:title" content="{{ title | default('Perysmith M2 Pro Max - Spot Cleaner Terbaik') }}">
    <meta property="og:description" content="Perysmith M2 Pro Max - Spot Cleaner terbaik dengan teknologi uap panas 100°C, AI Voice, dan daya hisap 20.000 Pa. Ambil promo spesial minggu ini!">
    <meta property="og:image" content="/images/logo.webp">
    
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="{{ site.domain }}">
    <meta name="twitter:title" content="{{ title | default('Perysmith M2 Pro Max - Spot Cleaner Terbaik') }}">
    <meta name="twitter:description" content="Perysmith M2 Pro Max - Spot Cleaner terbaik dengan teknologi uap panas 100°C, AI Voice, dan daya hisap 20.000 Pa. Ambil promo spesial minggu ini!">
    <meta name="twitter:image" content="/images/logo.webp">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <style>
    {% include "css/style.css" %}
    </style>

    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
</head>
<body>
    <header class="header">
        <nav class="navbar">
            <a href="#home" class="logo" aria-label="Perysmith logo">
                <img src="/images/logo.webp" class="logo-light" alt="Perysmith Logo" width="200" height="50" style="border-radius: 8px;"/>
                <img src="/images/light-perysmith.svg" class="logo-dark" alt="Perysmith Logo" width="200" height="50" style="border-radius: 8px;"/>
            </a>
      
            <div class="nav-controls">
                <button class="theme-toggle" aria-label="Toggle theme" style="background: none; border: none; cursor: pointer; color: var(--color-text); font-size: 1.2rem; margin-right: 10px;">
                    <i class="fa-solid fa-moon"></i>
                </button>
                <button class="nav-toggle" aria-label="Toggle navigation" id="navToggle">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
            <ul class="nav-links" id="navLinks">
                <li><a href="#home">Home</a></li>
                <li><a href="#keunggulan">Keunggulan</a></li>
                <li><a href="#cara-kerja">Cara Kerja</a></li>
                <li><a href="#harga">Harga</a></li>
                <li class="nav-links-cta">
                    <a href="https://wa.me/{{ site.whatsapp_number }}?text=Halo%2C%20saya%20tertarik%20dengan%20promo%20Perysmith%20M2%20Pro%20Max!" class="btn-nav-mobile" target="_blank" rel="noopener noreferrer">
                       <span class="nav-color-btn"><i class="fa-solid fa-cart-shopping"></i> Pesan Sekarang</span>
                    </a>
                </li>
            </ul>
       
            <div class="nav-backdrop" id="navBackdrop"></div>
            <div class="desktop-controls">
                <button class="theme-toggle" aria-label="Toggle theme" style="background: none; border: none; cursor: pointer; color: var(--color-text); font-size: 1.2rem;">
                    <i class="fa-solid fa-moon"></i>
                </button>
                <a href="https://wa.me/{{ site.whatsapp_number }}?text=Halo%2C%20saya%20tertarik%20dengan%20promo%20Perysmith%20M2%20Pro%20Max!" class="btn-nav" target="_blank" rel="noopener noreferrer">
                    <i class="fa-solid fa-cart-shopping"></i> Pesan Sekarang
                </a>
            </div>
        </nav>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer>
        <div class="footer-container">
            <div class="footer-col brand-col">
                <div class="footer-logo">PERYSMITH®</div>
                <p>Jl. Cikini Raya No.8, RT.8/RW.2,<br>Cikini, Kec. Menteng, Kota Jakarta<br>Pusat, Daerah Khusus Ibukota<br>Jakarta 10330</p>
                <p class="copyright">© copyright Rindra Aniko 2026</p>
            </div>
            <div class="footer-col links-col">
                <h4>Navigasi</h4>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#keunggulan">Keunggulan</a></li>
                    <li><a href="#cara-kerja">Cara Kerja</a></li>
                    <li><a href="#harga">Harga</a></li>
                </ul>
            </div>
            <div class="footer-col social-col">
                <h4>Sosial Media</h4>
                <div class="social-icons">
                    <a href="https://wa.me/{{ site.whatsapp_number }}?text=Halo%2C%20saya%20tertarik%20dengan%20promo%20Perysmith%20M2%20Pro%20Max!" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-whatsapp"></i></a>
                    <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <div class="wa-popup" id="waPopup">
        <div class="wa-bubble" id="waBubble">
            <span class="wa-bubble-text">Ambil Promo!</span>
            <button class="wa-bubble-close" id="waBubbleClose" aria-label="Tutup">&times;</button>
        </div>
        <a href="https://wa.me/{{ site.whatsapp_number }}?text=Halo%2C%20saya%20tertarik%20dengan%20promo%20Perysmith%20M2%20Pro%20Max!" class="wa-btn" target="_blank" rel="noopener noreferrer" aria-label="Chat WhatsApp">
            <i class="fa-brands fa-whatsapp"></i>
        </a>
        <div class="wa-pulse"></div>
    </div>

    <script src="/js/main.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" media="print" onload="this.media='all'">
</body>
</html>